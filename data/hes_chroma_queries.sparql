# list category that mon:691 "ALUM WORKS" is a member of
# including the colour associated with the category
# (should be only one category - "Industrial" #4E0047) 
PREFIX skos: <http://www.w3.org/2004/02/skos/core#>
PREFIX schema: <https://schema.org/>
PREFIX mon: <http://purl.org/heritagedata/schemes/1/concepts/>

SELECT DISTINCT ?lbl ?col 
WHERE {
	?uri skos:member mon:691;
		skos:prefLabel ?lbl;
		schema:color ?col .
	FILTER(langMatches(lang(?lbl), "EN"))
}
ORDER BY ?lbl


# list concepts that are members of the "cultivation" category (C102)
PREFIX skos: <http://www.w3.org/2004/02/skos/core#>
PREFIX coll: <http://purl.org/heritagedata/schemes/1/collections/>

SELECT DISTINCT ?uri ?lbl 
WHERE {
	coll:C102 skos:member ?uri .
	OPTIONAL { ?uri skos:prefLabel ?lbl }
	FILTER(langMatches(lang(?lbl), "en")) .
   
}
ORDER BY ?lbl

Results:
<http://purl.org/heritagedata/schemes/1/concepts/56>	"CORD RIG"@en
<http://purl.org/heritagedata/schemes/1/concepts/47>	"CULTIVATION REMAINS"@en
