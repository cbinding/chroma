# SPARQL queries to run on RDF data to view HES CHROMA data
# (Endpoint = https://heritagedata.org/live/sparql.php)


# list legend categories with colours and member count
PREFIX skos: <http://www.w3.org/2004/02/skos/core#>
PREFIX dct: <http://purl.org/dc/terms/>
PREFIX aat: <http://vocab.getty.edu/aat/>
PREFIX schema: <https://schema.org/>

SELECT DISTINCT	?uri ?lbl ?col count(?mem) AS ?counter 
WHERE {
	?uri a skos:Collection ;
		dct:type aat:300435413 ;
		schema:color ?col ;
		skos:prefLabel ?lbl ;
		skos:member ?mem .
	FILTER(langMatches(lang(?lbl), "EN"))
}
GROUP BY ?lbl ?col
ORDER BY ?lbl

Results:
uri	lbl	col	counter
http://purl.org/heritagedata/schemes/1/collections/C101	Buildings	#F96288	464
http://purl.org/heritagedata/schemes/1/collections/C102	Cultivation	#0AB5A1	7
